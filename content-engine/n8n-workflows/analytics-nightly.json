      "position": [1040, 380],
      "parameters": {
        "method": "GET",
        "url": "=https://graph.facebook.com/v22.0/{{ $('Get Published Content from Supabase').item.json.visual_assets.threads_post_id }}",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "fields",
              "value": "id,text,views,likes,replies,reposts,quotes"
            },
            {
              "name": "access_token",
              "value": "={{ $credential.accessToken }}"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "notes": "Meta Threads API: GET /{post-id}?fields=id,text,views,likes,replies,reposts,quotes. Uses same Meta access token as Instagram. Threads API became stable in 2024."
    },
    {
      "id": "threads-upsert-analytics",
      "name": "Threads: Upsert platform_analytics",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [1260, 380],
      "credentials": {
        "supabaseApi": {
          "id": "SUPABASE_CRED_ID_PLACEHOLDER",
          "name": "Supabase Content Engine"
        }
      },
      "parameters": {
        "operation": "upsert",
        "table": "platform_analytics",
